# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, never expose to the client.
# Used by lib/supabase/admin.ts and scripts/*.mjs
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Numeric id of the default outlet row (seeded by 0001 migration, usually 1)
NEXT_PUBLIC_DEFAULT_OUTLET_ID=1

# Public base URL of the deployed site, used for auth redirect links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret for external storefront clients posting to /api/orders.
# When set, any request that sends an `x-storefront-token` header must match
# this value (same-origin POS/checkout send no header and are unaffected).
# Must equal BILLJOT_ORDER_TOKEN in each storefront. Leave unset to disable.
STOREFRONT_ORDER_TOKEN=

# Apex domain for per-store subdomain routing (e.g. billjot.app → stores live
# at cafemocha.billjot.app). LEAVE UNSET for path-based routing (/r/<slug>),
# which is the default for local dev and preview deploys. For local subdomain
# testing, set to "lvh.me" and visit e.g. http://cafemocha.lvh.me:3000
# NEXT_PUBLIC_ROOT_DOMAIN=billjot.app
#
# NOTE: Custom domains (a tenant's OWN domain, e.g. order.cafemocha.com) are
# NOT configured here — they're per-tenant and dynamic. Each restaurant sets
# its domain in Admin → Settings, which writes restaurants.custom_domain; the
# middleware resolves it via the restaurant_slug_for_domain() RPC. You only set
# NEXT_PUBLIC_ROOT_DOMAIN (above) for the shared *.subdomain space.
